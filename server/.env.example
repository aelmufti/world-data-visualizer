# Server Configuration
PORT=8000
NODE_ENV=development

# Database
DB_PATH=./data/financial_news.duckdb

# AIS Stream API (for vessel tracking)
AIS_STREAM_API_KEY=your_ais_stream_api_key_here

# News Source API (optional - use RSS worker instead)
NEWS_SOURCE_API_URL=https://api.example.com/news
NEWS_SOURCE_API_KEY=your_api_key_here
