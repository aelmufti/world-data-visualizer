VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# URL du serveur proxy (optionnel, par défaut http://localhost:3001)
VITE_API_URL=http://localhost:3001

# URL Ollama (optionnel, par défaut http://localhost:11434)
VITE_OLLAMA_URL=http://localhost:11434

# NewsAPI pour actualités en temps réel (gratuit, 100 requêtes/jour)
# Obtenir une clé sur: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ============================================================================
# News Aggregator Configuration
# ============================================================================

# NewsAPI Configuration
NEWSAPI_ENABLED=true
NEWSAPI_TIMEOUT=3000
NEWSAPI_MAX_ARTICLES=10

# Bing News Configuration
BING_ENABLED=true
BING_TIMEOUT=3000
BING_MAX_ARTICLES=10

# Google News Configuration
GOOGLE_ENABLED=true
GOOGLE_TIMEOUT=3000
GOOGLE_MAX_ARTICLES=10

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=900000
CACHE_MAX_SIZE=100

# Scoring Configuration
SCORING_TITLE_WEIGHT=0.5
SCORING_SNIPPET_WEIGHT=0.3
SCORING_RECENCY_WEIGHT=0.2
SCORING_KEYWORD_BONUS=0.1

# Deduplication Configuration
DEDUP_ENABLED=true
DEDUP_THRESHOLD=0.7

# Filtering Configuration
FILTER_MIN_SCORE=0.3
FILTER_FALLBACK_SCORE=0.2
FILTER_MIN_ARTICLES=5
FILTER_MAX_ARTICLES=20
